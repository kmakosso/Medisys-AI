# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://medisys:secret@db:5432/medisys_db

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=change_me_generate_a_random_64_byte_hex_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Encryption at rest (AES-GCM) ───────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change_me_generate_a_fernet_key

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ─── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute

# ─── Postgres (used by docker-compose) ──────────────────────────────────────
POSTGRES_USER=medisys
POSTGRES_PASSWORD=secret
POSTGRES_DB=medisys_db
